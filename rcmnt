    echo -e "${CYAN}Usage:${NC} ${WHITE}rcmnt [OPTION]${NC}"
    echo

    show_section "Quick Start"
    echo "  rcmnt --setup            First-run setup wizard"
    echo "  rcmnt --doctor           Check dependencies"
    echo
    echo "  rcmnt --mount            Mount the remote drive"
    echo "  rcmnt --menu             Launch interactive menu"
    echo
    echo "  ${DIM}Run without arguments for interactive menu${NC}"
    echo

    show_section "Mount Operations"
    echo "  -m, --mount              Mount the remote drive"
    echo "  -u, --unmount            Unmount the remote drive"
    echo "  -r, --restart            Restart the mount"
    echo "  -s, --status             Show detailed status"
    echo

    show_section "Monitoring"
    echo "  -w, --watch              Monitor resources in real-time"
    echo "  -c, --health             Run health check"
    echo "  -l, --logs [MODE] [N]    View logs"
    echo "       Modes: --tail/-t (follow), --errors/-e, --full"
