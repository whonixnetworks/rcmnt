    echo "  rcmnt --mount"
    echo "  rcmnt --status"
    echo "  rcmnt --health"
    echo "  rcmnt --logs --errors"
    echo "  rcmnt --bwlimit 10M"
    echo "  rcmnt --menu"
}

# ── Initialise ──────────────────────────────────────────────────────────────────
mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$CONFIG_FILE")"
load_config

# Warn if not configured (skip for setup, init, help, version, doctor)
if [[ -z "$REMOTE" ]] && [[ "${1:-}" != "--setup" && "${1:-}" != "--init" && "${1:-}" != "-h" && "${1:-}" != "--help" && "${1:-}" != "-v" && "${1:-}" != "--version" && "${1:-}" != "--doctor" ]]; then
    echo -e "${YELLOW}⚠ rcmnt not configured. Run 'rcmnt --setup' to get started.${NC}"
    echo -e "${DIM}Or run 'rcmnt --help' for available options.${NC}"
    echo
fi

# ── Argument Parsing ────────────────────────────────────────────────────────────
case "${1:-}" in
    -m|--mount)              mount_drive ;;
    -u|--unmount)            unmount_drive ;;
    -s|--status)             show_status ;;
    -r|--restart)            restart_drive ;;
    -c|--health|--check)     check_health ;;
    --clean-cache|--cc)      clean_cache ;;
    --rotate-logs)           rotate_logs ;;
    --save-config)           save_config ;;
    --install-service|--service-install)     install_service ;;
    --uninstall-service|--service-uninstall) uninstall_service ;;
    -w|--watch|--monitor)    monitor_resources ;;
    --menu|--interactive|"") interactive_menu ;;
    --setup|--init)          setup_wizard ;;
    -h|--help)               show_help ;;
    -v|--version)            echo "rcmnt v1.5.0" ;;
    --doctor)                check_dependencies ;;

    --bwlimit|--bw)
        [[ $# -ge 2 ]] || die "--bwlimit requires an argument (e.g. 10M, off)"
        set_bandwidth "$2"
        ;;

    -l|--logs)
        shift
        mode="tail"; lines="50"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --tail|-t|--follow) mode="--tail" ;;
                --errors|-e)        mode="--errors" ;;
                --full)             mode="--full" ;;
                [0-9]*)             lines="$1" ;;
                *)                  break ;;
            esac
            shift
        done
        view_logs "$mode" "$lines"
        ;;

    *)
        log_error "Unknown option: $1"
        echo "Try 'rcmnt --help' for more information."
        exit 1
        ;;
esac
